# ─────────────────────────────────────────────────────────
#  Unigroup Transporters – Environment Variables
#  Copy this file to .env and fill in your real values
# ─────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Email (Nodemailer) – use your real SMTP credentials
# For Gmail: enable "App Passwords" in your Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email routing
EMAIL_FROM=website@unigrouptransporters.co.ke
EMAIL_TO=info@unigrouptransporters.co.ke

# Company info shown in emails
COMPANY_NAME=Unigroup Transporters Limited
COMPANY_PHONE=+254 700 000 000

# Security
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
